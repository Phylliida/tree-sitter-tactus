{
  "grammars": [
    {
      "name": "tactus",
      "camelcase": "Tactus",
      "scope": "source.tactus",
      "path": ".",
      "file-types": [
        "rs"
      ],
      "highlights": [
        "queries/highlights.scm"
      ],
      "injections": [
        "queries/injections.scm"
      ],
      "tags": [
        "queries/tags.scm"
      ],
      "injection-regex": "tactus"
    }
  ],
  "metadata": {
    "version": "0.1.0",
    "license": "MIT",
    "description": "Tactus grammar for tree-sitter"
  },
  "bindings": {
    "c": true,
    "go": true,
    "node": true,
    "python": true,
    "rust": true,
    "swift": true
  }
}
